# apps/web build-time environment contract
#
# These are the ONLY two variables the web SPA consumes. Both are Vite
# build-time vars (the VITE_ prefix bakes them into the static bundle) and
# are injected at Vercel build time from the Vercel env store (D-07/D-08) —
# never committed with real values.
#
# NOTE: VITE_CLERK_PUBLISHABLE_KEY is a *publishable* (public) key by design.
# No Clerk secret key belongs in the web app — a secret key must never be
# baked into a publicly-served bundle.

# Clerk publishable key.
#   dev:  pk_test_...
#   prod: pk_live_...  (from the Plan 07 production Clerk instance)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Base URL of the API.
#   dev:  http://localhost:3001
#   prod: the Railway API URL (from Plan 05), e.g. https://<service>.up.railway.app
VITE_API_BASE_URL=http://localhost:3001
