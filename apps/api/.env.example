DATABASE_URL=postgresql://user:password@localhost:5432/ais_marketplace
PORT=3001
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Canonical frontend URL used to build email CTA links (services/email.ts).
# This is a SINGLE URL — do NOT overload it into the CORS allowlist below.
FRONTEND_URL=http://localhost:5173

# CORS allowlist (cross-origin: Vercel SPA -> Railway API). Comma-separated list
# of exact origins that may call the API. Also feeds Clerk authorizedParties.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Optional regex matching ephemeral preview origins (e.g. Vercel preview URLs
# https://<project>-<hash>-<scope>.vercel.app). Leave unset to disable previews.
# CORS_PREVIEW_PATTERN=^https://myproject-[a-z0-9]+-myscope\.vercel\.app$

# Production hardening (D-08): the deployed API must set NODE_ENV=production and
# must NOT set NODE_TLS_REJECT_UNAUTHORIZED (that dev-only cert workaround is
# unsafe in prod — real certificates verify correctly).

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_api_token_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_api_token_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-bucket.your-account-id.r2.dev
